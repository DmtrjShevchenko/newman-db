    {
      "name": "15.2_Order_docs.sql",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-XSRF-TOKEN",
            "value": "{{XSRF-TOKEN1}}",
            "type": "default"
          },
          {
            "key": "JSESSIONID",
            "value": "{{JSESSIONID2}}",
            "type": "default"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\nSELECT to_char (doc.documentdate,'dd.mm.yyyy') documentdate, \r\n       doc.documenttypeid,\r\n       doc.accountano,\r\n       doc.accountbno,\r\n       doc.summa,\r\n       doc.currencyid,\r\n       doc.documentstateid,\r\n       doc.platpurpose,\r\n       doc.documentstreamid,\r\n       to_char (doc.valuedate,'dd.mm.yyyy') valuedate\r\n  FROM document_cur doc\r\n WHERE doc.id IN ( SELECT l2.documentid\r\n                     FROM atmencashorderdoc ad\r\n                     JOIN document_cur d ON ad.docsequenceid = d.docsequenceid\r\n                     JOIN Doc2Oper_Link l ON d.id = l.documentid\r\n                     JOIN Doc2Oper_Link l2 ON l.globalsequenceid = l2.globalsequenceid\r\n                    WHERE ad.orderid = 45\r\n                      AND ad.actionid = 4)                      \r\n order by doc.id\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "db://",
          "protocol": "db"
        }
      },
      "response": []
    },
